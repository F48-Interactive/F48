// ─────────────────────────────────────────────────────────────────────────────
// F48 Backend — Prisma Schema
// ARCH-004: Prisma schema and migrations define database evolution.
//           Direct production schema edits are prohibited.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  player
  organizer
  admin
  super_admin
}

enum UserStatus {
  active
  suspended
  banned
}

enum PlayerStatus {
  onboarding
  active
  suspended
  banned
}

enum FfBindingStatus {
  active
  replaced
  removed
}

enum OrgVerificationStatus {
  profile_incomplete
  verification_pending
  verified
  restricted
  suspended
}

enum FundingEligibility {
  not_eligible
  eligible
  suspended
}

enum VerificationDecision {
  approved
  rejected
  restricted
  suspended
  reinstated
}

// ─────────────────────────────────────────────────────────────────────────────
// IDENTITY & AUTH (Phase 0/1 tables)
// ─────────────────────────────────────────────────────────────────────────────

/// Internal account linked to Firebase subject (DATA-001).
model User {
  id          String     @id @default(uuid()) @db.Uuid
  firebaseUid String     @unique @map("firebase_uid")
  email       String
  role        UserRole   @default(player)
  status      UserStatus @default(active)
  isDeleted   Boolean    @default(false) @map("is_deleted")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  player    Player?
  organizer Organizer?
  auditLogs AuditLog[]

  @@map("users")
}

/// Player profile with Platform ID (PLAYER-001/002).
model Player {
  id            String       @id @default(uuid()) @db.Uuid
  userId        String       @unique @map("user_id") @db.Uuid
  platformId    String       @unique @map("platform_id") @db.VarChar(9)
  username      String       @unique @db.VarChar(20)
  usernameLower String       @unique @map("username_lower") @db.VarChar(20)
  displayName   String?      @map("display_name")
  avatarAssetId String?      @map("avatar_asset_id") @db.Uuid
  status        PlayerStatus @default(onboarding)
  isDeleted     Boolean      @default(false) @map("is_deleted")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user       User              @relation(fields: [userId], references: [id])
  ffBindings PlayerFfBinding[]

  @@map("players")
}

/// Free Fire UID binding (PLAYER-004/005).
/// Partial unique: only one active binding per UID at a time (DATA-007).
model PlayerFfBinding {
  id            String          @id @default(uuid()) @db.Uuid
  playerId      String          @map("player_id") @db.Uuid
  ffUid         String          @map("ff_uid")
  ffNickname    String?         @map("ff_nickname")
  ffRegion      String?         @map("ff_region")
  ffLevel       Int?            @map("ff_level")
  ffAccountData Json?           @map("ff_account_data")
  status        FfBindingStatus @default(active)
  boundAt       DateTime        @default(now()) @map("bound_at") @db.Timestamptz
  unboundAt     DateTime?       @map("unbound_at") @db.Timestamptz
  unboundReason String?         @map("unbound_reason")

  // Relations
  player Player @relation(fields: [playerId], references: [id])

  // Partial unique constraint: only one active binding per UID globally.
  // Prisma cannot express WHERE conditions — created as raw SQL in migration:
  //   CREATE UNIQUE INDEX unique_active_ff_uid ON player_ff_bindings (ff_uid)
  //     WHERE status = 'active';
  @@index([playerId, status], name: "idx_ff_binding_player_status")
  @@index([ffUid], name: "idx_ff_binding_uid")
  @@map("player_ff_bindings")
}

/// Organizer profile with YouTube verification (ORG-ID-001/002).
model Organizer {
  id                          String              @id @default(uuid()) @db.Uuid
  userId                      String              @unique @map("user_id") @db.Uuid
  displayName                 String?             @map("display_name")
  description                 String?
  avatarAssetId               String?             @map("avatar_asset_id") @db.Uuid
  verificationStatus          OrgVerificationStatus @default(profile_incomplete) @map("verification_status")
  fundingEligibility          FundingEligibility  @default(not_eligible) @map("funding_eligibility")
  verifiedAt                  DateTime?           @map("verified_at") @db.Timestamptz
  verifiedBy                  String?             @map("verified_by") @db.Uuid
  totalTournamentsCompleted   Int                 @default(0) @map("total_tournaments_completed")
  totalPrizesDistributedPaise BigInt              @default(0) @map("total_prizes_distributed_paise")
  isDeleted                   Boolean             @default(false) @map("is_deleted")
  createdAt                   DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                   DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user                 User                        @relation(fields: [userId], references: [id])
  youtubeChannels      OrganizerYoutubeChannel[]
  verificationDecisions OrgVerificationDecision[]
  tournaments          Tournament[]

  @@map("organizers")
}

/// YouTube channel data fetched server-side (ORG-ID-002).
model OrganizerYoutubeChannel {
  id              String   @id @default(uuid()) @db.Uuid
  organizerId     String   @map("organizer_id") @db.Uuid
  channelId       String   @map("channel_id")
  channelName     String?  @map("channel_name")
  handle          String?
  url             String?
  imageUrl        String?  @map("image_url")
  subscriberCount Int?     @map("subscriber_count")
  videoCount      Int?     @map("video_count")
  rawChannelData  Json?    @map("raw_channel_data")
  status          String   @default("active")
  fetchedAt       DateTime @default(now()) @map("fetched_at") @db.Timestamptz
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  organizer Organizer @relation(fields: [organizerId], references: [id])

  @@map("organizer_youtube_channels")
}

/// Immutable verification decision record (ORG-ID-003).
model OrgVerificationDecision {
  id          String               @id @default(uuid()) @db.Uuid
  organizerId String               @map("organizer_id") @db.Uuid
  decision    VerificationDecision
  reason      String
  reviewerId  String               @map("reviewer_id") @db.Uuid
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  organizer Organizer @relation(fields: [organizerId], references: [id])

  @@map("organizer_verification_decisions")
}

// ─────────────────────────────────────────────────────────────────────────────
// PLATFORM & AUDIT (Phase 0 tables)
// ─────────────────────────────────────────────────────────────────────────────

/// Immutable audit log (ADMIN-011, DATA-004).
model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  actorId       String   @map("actor_id") @db.Uuid
  actorRole     String   @map("actor_role")
  action        String
  resourceType  String   @map("resource_type")
  resourceId    String   @map("resource_id")
  oldValue      Json?    @map("old_value")
  newValue      Json?    @map("new_value")
  reason        String?
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  correlationId String?  @map("correlation_id")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  actor User @relation(fields: [actorId], references: [id])

  @@index([resourceType, resourceId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Status transition history (LIFE-002).
model StatusHistory {
  id             String   @id @default(uuid()) @db.Uuid
  resourceType   String   @map("resource_type")
  resourceId     String   @map("resource_id")
  previousStatus String   @map("previous_status")
  newStatus      String   @map("new_status")
  reason         String?
  actorId        String   @map("actor_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("status_history")
}

/// Feature flags (ADMIN-012).
model FeatureFlag {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  value       Boolean  @default(false)
  description String?
  updatedBy   String?  @map("updated_by") @db.Uuid
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("feature_flags")
}

/// Idempotency key storage (ARCH-006).
model IdempotencyKey {
  id             String   @id @default(uuid()) @db.Uuid
  key            String   @unique
  resourceType   String   @map("resource_type")
  resourceId     String?  @map("resource_id")
  responseStatus Int      @map("response_status")
  responseBody   Json?    @map("response_body")
  expiresAt      DateTime @map("expires_at") @db.Timestamptz
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([expiresAt])
  @@map("idempotency_keys")
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 2 ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum TournamentStatus {
  draft
  submitted
  changes_required
  approved
  published
  registration_open
  registration_closed
  check_in
  live
  results_pending
  dispute_window
  results_final
  settlement
  completed
  canceled
  voided
  archived
}

enum TournamentMode {
  solo
  duo
  squad
}

enum FundingType {
  f48_sponsored
  entry_fee
}

enum StructureType {
  direct_final
  qualifiers_to_final
}

enum ScoringModel {
  combined
  placement_only
  kills_only
}

enum StageType {
  qualifier
  final
}

enum MatchStatus {
  scheduled
  check_in
  room_released
  live
  awaiting_result
  result_submitted
  finalized
  delayed
  canceled
  voided
}

enum FundingRequestStatus {
  not_requested
  draft
  submitted
  changes_required
  partially_approved
  approved
  rejected
  canceled
  settled
}

enum BannerLinkType {
  tournament
  organizer
  announcement
  external
}

enum MediaPurpose {
  tournament_banner
  organizer_avatar
  player_avatar
  result_evidence
  dispute_evidence
  sponsor_logo
  banner_image
  deposit_proof
}

enum MediaAccessLevel {
  public_access
  authenticated
  restricted
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 2: TOURNAMENT & FUNDING TABLES
// ─────────────────────────────────────────────────────────────────────────────

/// Core tournament entity (TOUR-001 to TOUR-004).
model Tournament {
  id                    String           @id @default(uuid()) @db.Uuid
  organizerId           String           @map("organizer_id") @db.Uuid
  title                 String           @db.VarChar(100)
  description           String?
  mode                  TournamentMode
  fundingType           FundingType      @map("funding_type")
  structureType         StructureType    @map("structure_type")
  scoringModel          ScoringModel     @map("scoring_model")
  status                TournamentStatus @default(draft)
  gameMapId             String?          @map("game_map_id") @db.Uuid
  bannerAssetId         String?          @map("banner_asset_id") @db.Uuid
  maxUnits              Int              @map("max_units")
  entryFeePaise         BigInt?          @map("entry_fee_paise")
  prizePoolPaise        BigInt           @default(0) @map("prize_pool_paise")
  scheduledStartAt      DateTime?        @map("scheduled_start_at") @db.Timestamptz
  registrationOpenAt    DateTime?        @map("registration_open_at") @db.Timestamptz
  registrationCloseAt   DateTime?        @map("registration_close_at") @db.Timestamptz
  checkInDurationMin    Int?             @map("check_in_duration_min")
  disputeWindowHours    Int              @default(24) @map("dispute_window_hours")
  rulesText             String?          @map("rules_text")
  activeConfigVersionId String?          @map("active_config_version_id") @db.Uuid
  version               Int              @default(1) // Optimistic concurrency
  isDeleted             Boolean          @default(false) @map("is_deleted")
  createdAt             DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  organizer       Organizer               @relation(fields: [organizerId], references: [id])
  stages          TournamentStage[]
  rooms           TournamentRoom[]
  matches         TournamentMatch[]
  configVersions  TournamentConfigVersion[]
  fundingRequest  FundingRequest?
  gameMap         MapCatalog?              @relation(fields: [gameMapId], references: [id])

  @@index([organizerId])
  @@index([status])
  @@index([scheduledStartAt])
  @@map("tournaments")
}

/// Tournament stage (qualifier or final).
model TournamentStage {
  id                  String    @id @default(uuid()) @db.Uuid
  tournamentId        String    @map("tournament_id") @db.Uuid
  type                StageType
  name                String    @db.VarChar(50)
  stageOrder          Int       @map("stage_order")
  advancementCount    Int?      @map("advancement_count")
  pointsCarryForward  Boolean   @default(false) @map("points_carry_forward")
  checkInDurationMin  Int?      @map("check_in_duration_min")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tournament  Tournament        @relation(fields: [tournamentId], references: [id])
  rooms       TournamentRoom[]
  matches     TournamentMatch[]

  @@unique([tournamentId, stageOrder])
  @@map("tournament_stages")
}

/// Room within a stage (TOUR-001: 48 solo / 24 duo / 12 squad max).
model TournamentRoom {
  id              String   @id @default(uuid()) @db.Uuid
  tournamentId    String   @map("tournament_id") @db.Uuid
  stageId         String   @map("stage_id") @db.Uuid
  name            String   @db.VarChar(50)
  maxUnits        Int      @map("max_units")
  roomOrder       Int      @map("room_order")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tournament  Tournament        @relation(fields: [tournamentId], references: [id])
  stage       TournamentStage   @relation(fields: [stageId], references: [id])
  matches     TournamentMatch[]

  @@unique([tournamentId, stageId, roomOrder])
  @@map("tournament_rooms")
}

/// Match within a room (TOUR-003: every match → one room + one stage).
model TournamentMatch {
  id              String      @id @default(uuid()) @db.Uuid
  tournamentId    String      @map("tournament_id") @db.Uuid
  stageId         String      @map("stage_id") @db.Uuid
  roomId          String      @map("room_id") @db.Uuid
  matchNumber     Int         @map("match_number")
  status          MatchStatus @default(scheduled)
  scheduledAt     DateTime?   @map("scheduled_at") @db.Timestamptz
  startedAt       DateTime?   @map("started_at") @db.Timestamptz
  endedAt         DateTime?   @map("ended_at") @db.Timestamptz
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tournament  Tournament      @relation(fields: [tournamentId], references: [id])
  stage       TournamentStage @relation(fields: [stageId], references: [id])
  room        TournamentRoom  @relation(fields: [roomId], references: [id])

  @@unique([tournamentId, matchNumber])
  @@index([status])
  @@map("tournament_matches")
}

/// Versioned scoring/prize/tiebreak config (DATA-005, SCORE-009).
model TournamentConfigVersion {
  id              String       @id @default(uuid()) @db.Uuid
  tournamentId    String       @map("tournament_id") @db.Uuid
  versionNumber   Int          @map("version_number")
  scoringModel    ScoringModel @map("scoring_model")
  killMultiplier  Decimal      @default(1) @map("kill_multiplier") @db.Decimal(5, 2)
  isLocked        Boolean      @default(false) @map("is_locked")
  lockedAt        DateTime?    @map("locked_at") @db.Timestamptz
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tournament      Tournament       @relation(fields: [tournamentId], references: [id])
  placementPoints PlacementPoints[]
  prizeRules      PrizeRule[]
  tiebreakRules   TiebreakRule[]

  @@unique([tournamentId, versionNumber])
  @@map("tournament_config_versions")
}

/// Placement position → points (SCORE-001/002).
model PlacementPoints {
  id                String @id @default(uuid()) @db.Uuid
  configVersionId   String @map("config_version_id") @db.Uuid
  position          Int
  points            Decimal @db.Decimal(8, 2)

  configVersion TournamentConfigVersion @relation(fields: [configVersionId], references: [id])

  @@unique([configVersionId, position])
  @@map("placement_points")
}

/// Prize distribution rule per rank (PRIZE-001/002/003).
model PrizeRule {
  id                String @id @default(uuid()) @db.Uuid
  configVersionId   String @map("config_version_id") @db.Uuid
  rankStart         Int    @map("rank_start")
  rankEnd           Int    @map("rank_end")
  amountPaise       BigInt @map("amount_paise")

  configVersion TournamentConfigVersion @relation(fields: [configVersionId], references: [id])

  @@unique([configVersionId, rankStart])
  @@map("prize_rules")
}

/// Ordered tiebreak fields (SCORE-010).
model TiebreakRule {
  id                String @id @default(uuid()) @db.Uuid
  configVersionId   String @map("config_version_id") @db.Uuid
  priority          Int
  field             String @db.VarChar(50)

  configVersion TournamentConfigVersion @relation(fields: [configVersionId], references: [id])

  @@unique([configVersionId, priority])
  @@map("tiebreak_rules")
}

/// Funding request lifecycle (9 states).
model FundingRequest {
  id              String               @id @default(uuid()) @db.Uuid
  tournamentId    String               @unique @map("tournament_id") @db.Uuid
  requestedPaise  BigInt               @map("requested_paise")
  approvedPaise   BigInt?              @map("approved_paise")
  status          FundingRequestStatus @default(not_requested)
  reason          String?
  adminNotes      String?              @map("admin_notes")
  depositProofId  String?              @map("deposit_proof_id") @db.Uuid
  reviewedBy      String?              @map("reviewed_by") @db.Uuid
  reviewedAt      DateTime?            @map("reviewed_at") @db.Timestamptz
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tournament Tournament @relation(fields: [tournamentId], references: [id])

  @@index([status])
  @@map("funding_requests")
}

/// Hero carousel banners.
model Banner {
  id           String         @id @default(uuid()) @db.Uuid
  title        String         @db.VarChar(100)
  subtitle     String?        @db.VarChar(200)
  imageAssetId String         @map("image_asset_id") @db.Uuid
  linkType     BannerLinkType @map("link_type")
  linkId       String?        @map("link_id")
  linkUrl      String?        @map("link_url")
  priority     Int            @default(0)
  isActive     Boolean        @default(true) @map("is_active")
  startsAt     DateTime?      @map("starts_at") @db.Timestamptz
  endsAt       DateTime?      @map("ends_at") @db.Timestamptz
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  @@index([isActive, priority])
  @@map("banners")
}

/// Game map catalog.
model MapCatalog {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @db.VarChar(50)
  gameCode    String       @map("game_code") @db.VarChar(20)
  imageUrl    String?      @map("image_url")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz

  tournaments Tournament[]

  @@map("map_catalog")
}

/// Uploaded media asset tracking (MEDIA-001/002).
model MediaAsset {
  id           String           @id @default(uuid()) @db.Uuid
  uploaderId   String           @map("uploader_id") @db.Uuid
  purpose      MediaPurpose
  accessLevel  MediaAccessLevel @default(public_access) @map("access_level")
  cloudinaryId String           @map("cloudinary_id")
  url          String
  secureUrl    String           @map("secure_url")
  format       String           @db.VarChar(10)
  width        Int?
  height       Int?
  sizeBytes    Int              @map("size_bytes")
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz

  @@index([uploaderId])
  @@index([purpose])
  @@map("media_assets")
}

