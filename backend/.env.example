# F48 Backend - Environment Configuration
# Copy to .env and fill in your values.

NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

DATABASE_URL=postgresql://user:password@localhost:5432/f48_dev?schema=public
REDIS_URL=redis://localhost:6379

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

SESSION_SECRET=your-session-secret-at-least-32-characters-long
SESSION_MAX_AGE_MS=604800000
COOKIE_DOMAIN=
ROOM_CREDENTIALS_SECRET=your-room-credentials-secret-at-least-32-chars

GAMES_KINBO_API_URL=https://api.gameskinbo.com
GAMES_KINBO_API_KEY=your-games-kinbo-api-key

YOUTUBE_API_KEY=

CORS_ORIGINS=http://localhost:3001

THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100

LOG_LEVEL=debug
