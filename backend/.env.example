# ─────────────────────────────────────────────────────────────────────────────
# F48 Backend — Environment Configuration
# Copy to .env and fill in your values.
# ARCH-011: All secrets in env vars only. Never in committed source.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql://user:password@localhost:5432/f48_dev?schema=public

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Firebase Admin SDK ──
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# ── Session / Cookies ──
SESSION_SECRET=your-session-secret-at-least-32-characters-long
SESSION_MAX_AGE_MS=604800000
COOKIE_DOMAIN=

# ── Cloudinary ──
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Games Kinbo (Free Fire UID Lookup) ──
GAMES_KINBO_API_URL=https://api.gameskinbo.com
GAMES_KINBO_API_KEY=your-games-kinbo-api-key

# ── YouTube Data API (optional — mock adapter used if absent) ──
YOUTUBE_API_KEY=

# ── CORS ──
CORS_ORIGINS=http://localhost:3001

# ── Rate Limiting ──
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100

# ── Logging ──
LOG_LEVEL=debug
